  "keyFeatures": [
    "CLI tool for extracting agent-readable metadata from Solidity contracts",
    "Custom NatSpec tags for declaring function intent, preconditions, effects, and risks",
    "Schema-compliant JSON output for machine consumption",
    "EVM function selector generation from Solidity signatures",
    "Support for contract-level invariants and event documentation",
    "Onchain metadata discovery via IIntentSpec interface",
    "Batch compilation of multiple Solidity files",
    "Integration with IPFS and content-addressed storage"
  ],
  "publicApiSurface": [
    "intentspec compile",
    "intentspec extract-natspec",
    "extractNatSpec(filePath)",
